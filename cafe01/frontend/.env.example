# Copy to .env.local for local dev. On Vercel, add these in Project → Settings → Environment Variables.

# MongoDB Atlas (required for Vercel — localhost will not work in production)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/cafe?retryWrites=true&w=majority

# NextAuth
NEXTAUTH_SECRET=generate_a_long_random_string
NEXTAUTH_URL=https://your-app.vercel.app

# JWT for OTP signup flow
JWT_SECRET=generate_a_long_random_string

# Email — Resend recommended on Vercel
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_TEST_EMAIL=

# Optional Gmail SMTP
EMAIL_USER=
EMAIL_PASS=

# Google OAuth — redirect: https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Optional
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
NEXT_PUBLIC_INSTAGRAM_READY=false
